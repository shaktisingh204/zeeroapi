# --- Server ---
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,melbet_saas_backend=debug

# --- Database ---
DATABASE_URL=postgres://melbet:melbet@localhost:5432/melbet
DATABASE_MAX_CONNECTIONS=10

# --- Auth ---
# Generate a long random string for production!
JWT_SECRET=change-me-to-a-long-random-secret-string-please
JWT_EXPIRY_HOURS=24

# First admin account, seeded on first boot if no users exist
BOOTSTRAP_ADMIN_EMAIL=admin@melbet-saas.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Shared key the Python page scraper uses to POST to /api/ingest/snapshot
INGEST_KEY=dev-ingest-key

# --- Scraper ---
# Base origin of the target site (no trailing slash)
MELBET_BASE_URL=https://india.melbet.com
# Language code used by the LineFeed/LiveFeed endpoints
MELBET_LANG=en
# Partner id used by the public feed endpoints (varies per skin)
MELBET_PARTNER=8
# How often (seconds) to refresh prematch lines
SCRAPE_PREMATCH_INTERVAL_SECS=300
# How often (seconds) to refresh live data
SCRAPE_LIVE_INTERVAL_SECS=20
# Polite delay between individual HTTP requests (ms)
SCRAPE_REQUEST_DELAY_MS=400
# Set to false to disable the background scheduler (manual scraping only)
SCRAPE_ENABLED=true

# --- CORS ---
# Comma separated list of allowed origins for the dashboard
CORS_ORIGINS=http://localhost:3000

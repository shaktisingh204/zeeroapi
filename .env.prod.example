# ZeroApi production secrets for docker-compose.prod.yml.
# Copy to `.env`, fill in real values, and NEVER commit the real `.env`.
#   cp .env.prod.example .env
# Generate strong secrets with:  openssl rand -hex 32

DB_NAME=zeroapi
DB_USER=zeroapi
DB_PASS=change-me-to-a-strong-password

JWT_SECRET=change-me-openssl-rand-hex-32
INGEST_KEY=change-me-openssl-rand-hex-24

BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.example
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong

# Public https origin (used for CORS, portal links, and the baked frontend API URL).
PUBLIC_URL=https://your-domain.example

# Email — leave SMTP_URL blank to use the file-log dev transport.
EMAIL_FROM=ZeroApi <no-reply@your-domain.example>
SMTP_URL=

# Stripe (optional — billing endpoints 404 without these).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
